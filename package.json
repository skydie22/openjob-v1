{
  "name": "openjob-api",
  "version": "1.0.0",
  "description": "OpenJob RESTful API - Internal Recruitment Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:dev": "nodemon server.js",
"migrate": "node-pg-migrate up --migrations-dir src/migrations --migrations-table pgmigrations",
"migrate:down": "node-pg-migrate down --migrations-dir src/migrations --migrations-table pgmigrations",
"migrate:create": "node-pg-migrate create --migrations-dir src/migrations"
  },
  "node-pg-migrate": {
    "migrationsTable": "pgmigrations",
    "dir": "src/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
